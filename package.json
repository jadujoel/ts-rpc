{
	"name": "@jadujoel/ts-rpc",
	"module": "lib.ts",
	"type": "module",
	"main": "dist/lib.js",
	"types": "dist/lib.d.ts",
	"private": false,
	"version": "0.0.5",
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		".": {
			"bun": "./lib.ts",
			"import": {
				"types": "./dist/lib.d.ts",
				"default": "./dist/lib.js"
			},
			"default": "./dist/lib.js"
		}
	},
	"scripts": {
		"validate": "bun run build && bun lint && bun test --coverage",
		"lint": "bunx biome lint",
		"build": "rm -rf dist && bunx tsc -p tsconfig.build.json",
		"typecheck": "bunx tsc --noEmit",
		"prepublishOnly": "bun run build"
	},
	"devDependencies": {
		"@types/bun": "1.3.10"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@biomejs/biome": "2.3.15",
		"zod": "4.3.6"
	},
	"files": [
		"apps",
		"docs",
		"examples",
		"shared",
		"lib.ts",
		"*.md",
		"*.ts",
		"*.json",
		"dist"
	]
}
